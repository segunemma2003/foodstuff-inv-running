# ── App ──────────────────────────────────────────────

# Local development — uses SQLite (no setup needed):
# DATABASE_URL=sqlite:///./foodstuff.db

# Railway PostgreSQL — copy the full URL from:
#   Railway dashboard → your Postgres service → Variables → DATABASE_URL
# Format:  postgresql://postgres:<PASSWORD>@postgres-production-5653.up.railway.app:<PORT>/railway
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres-production-5653.up.railway.app:5432/railway

SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated allowed CORS origins (leave blank to allow all — dev only)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# ── Redis (Celery broker + backend) ──────────────────
REDIS_URL=redis://localhost:6379/0

# ── SMTP Email ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=false          # true → SMTP_SSL (port 465); false → STARTTLS (port 587)
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Foodstuff Store
SMTP_FROM_EMAIL=noreply@foodstuffstore.com
INVOICE_PRIMARY_RECIPIENT_EMAIL=foodstuffstoreinvoices@gmail.com
COST_OF_SALES_RECIPIENT_EMAIL=foodstuffstorepo@gmail.com
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_TOKEN=

# ── App URLs (used in email links) ───────────────────
FRONTEND_URL=http://localhost:3000

# ── Paystack Payment Gateway ─────────────────────────
# Get your keys from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook URL to register in Paystack dashboard:
#   https://yourdomain.com/api/v1/payments/paystack/webhook

# ── AWS S3 (file uploads, generated PDFs/reports) ────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1
